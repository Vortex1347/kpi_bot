# Node env
NODE_ENV=development

# Core server
API_PORT=3000

# Telegram bot
TELEGRAM_BOT_TOKEN=replace_with_real_bot_token
LEAD_TELEGRAM_ID=replace_with_your_telegram_id

# CRM supervisor (web auth defaults)
CRM_SUPERVISOR_EMAIL=supervisor@example.com
CRM_SUPERVISOR_USERNAME=dev_supervisor
CRM_SUPERVISOR_PASSWORD=dev_password_change_me
CRM_SUPERVISOR_NAME=Supervisor

# Database container settings (for docker-compose.yml)
POSTGRES_USER=kpi_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=kpi_bot
POSTGRES_PORT=666

# Backend DB connection
DATABASE_URL=postgresql://kpi_user:change_me_strong_password@localhost:666/kpi_bot?schema=public

# Reports
REPORT_OUTPUT_DIR=reports
