generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  LEAD
  EMPLOYEE
}

enum CampaignStatus {
  CREATED
  ACTIVE
  CLOSED
  REPORT_GENERATED
}

model Employee {
  id         String                @id @default(uuid())
  telegramId String                @unique
  fullName   String
  department String
  role       UserRole              @default(EMPLOYEE)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  responses  EvaluationResponse[]
  campaigns  CampaignParticipant[]
}

model Campaign {
  id           String                @id @default(uuid())
  title        String
  status       CampaignStatus        @default(CREATED)
  startedAt    DateTime?
  closedAt     DateTime?
  createdBy    String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  responses    EvaluationResponse[]
  participants CampaignParticipant[]
}

model CampaignParticipant {
  id          String    @id @default(uuid())
  campaignId  String
  employeeId  String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([campaignId, employeeId])
}

model KpiQuestion {
  id            String               @id @default(uuid())
  code          String               @unique
  section       String
  text          String
  weightPercent Int
  sortOrder     Int                  @unique
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  responses     EvaluationResponse[]
}

model EvaluationResponse {
  id         String      @id @default(uuid())
  campaignId String
  employeeId String
  questionId String
  score      Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  question   KpiQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([campaignId, employeeId, questionId])
  @@index([campaignId])
  @@index([employeeId])
  @@index([questionId])
}
